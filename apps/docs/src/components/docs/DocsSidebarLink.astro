---
import { docsHref, type DocsNavItem } from '../../lib/docs-navigation';

interface Props {
	item: DocsNavItem;
	currentSlug: string;
}

const { item, currentSlug } = Astro.props;
const external = 'href' in item;
const active = !external && item.slug === currentSlug && item.anchor === undefined;
const children = !external ? item.items : undefined;
---

<a
	class:list={['group relative flex items-center py-1.5 text-sm font-normal leading-snug', active ? 'font-medium text-blue-600' : 'text-gray-600 hover:text-gray-950']}
	href={external ? item.href : docsHref(item.slug, item.anchor)}
	target={external ? '_blank' : undefined}
	rel={external ? 'noopener noreferrer' : undefined}
	aria-current={active ? 'page' : undefined}
	data-docs-sidebar-link={!external ? 'true' : undefined}
>
	{!external && item.icon === 'home' && (
		<svg class="mr-1.5 size-4 shrink-0 fill-current opacity-70" viewBox="0 0 640 640" aria-hidden="true">
			<path d="M341.8 72.6C329.5 61.2 310.5 61.2 298.3 72.6L74.3 280.6C64.7 289.6 61.5 303.5 66.3 315.7C71.1 327.9 82.8 336 96 336L112 336L112 512C112 547.3 140.7 576 176 576L464 576C499.3 576 528 547.3 528 512L528 336L544 336C557.2 336 569 327.9 573.8 315.7C578.6 303.5 575.4 289.5 565.8 280.6L341.8 72.6zM304 384L336 384C362.5 384 384 405.5 384 432L384 528L256 528L256 432C256 405.5 277.5 384 304 384z" />
		</svg>
	)}
	{item.title}
	{external && (
		<svg class="ml-1.5 size-4 shrink-0 text-gray-400 group-hover:text-gray-950" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true">
			<path d="M384 64C366.3 64 352 78.3 352 96C352 113.7 366.3 128 384 128L466.7 128L265.3 329.4C252.8 341.9 252.8 362.2 265.3 374.7C277.8 387.2 298.1 387.2 310.6 374.7L512 173.3L512 256C512 273.7 526.3 288 544 288C561.7 288 576 273.7 576 256L576 96C576 78.3 561.7 64 544 64L384 64zM144 160C99.8 160 64 195.8 64 240L64 496C64 540.2 99.8 576 144 576L400 576C444.2 576 480 540.2 480 496L480 416C480 398.3 465.7 384 448 384C430.3 384 416 398.3 416 416L416 496C416 504.8 408.8 512 400 512L144 512C135.2 512 128 504.8 128 496L128 240C128 231.2 135.2 224 144 224L224 224C241.7 224 256 209.7 256 192C256 174.3 241.7 160 224 160L144 160z" />
		</svg>
	)}
</a>
{children && (
	<ul class="m-0 list-none border-l border-docs-border pl-3">
		{children.map((child) => (
			<li class:list={['slug' in child && child.anchor !== undefined && 'docs-sidebar-location-item']}><Astro.self item={child} currentSlug={currentSlug} /></li>
		))}
	</ul>
)}
